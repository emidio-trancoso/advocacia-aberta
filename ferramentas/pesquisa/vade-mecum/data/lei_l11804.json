    "1": {
      "numero": "1",
      "texto": "Art. 1o Esta Lei disciplina o direito de alimentos da mulher gestante e a forma como será exercido.",
      "url": "https://www.planalto.gov.br/ccivil_03/_ato2007-2010/2008/lei/l11804.htm#:~:text=Art.%201o%20Esta%20Lei%20disciplina%20o%20direito%20de%20alimentos%20da%20mulher%20gestante%20e%20a%20forma%20como%20ser%C3%A1%20exercido.",
      "keywords": [],
