    "2": {
      "numero": "2",
      "texto": "Art. 2o No exercício da atividade de perícia oficial de natureza criminal, é assegurado autonomia técnica, científica e funcional, exigido concurso público, com formação acadêmica específica, para o provimento do cargo de perito oficial.",
      "url": "https://www.planalto.gov.br/ccivil_03/_ato2007-2010/2009/lei/l12030.htm#:~:text=Art.%202o%20No%20exerc%C3%ADcio%20da%20atividade%20de%20per%C3%ADcia%20oficial%20de%20natureza%20criminal%2C%20%C3%A9%20assegurado%20autonomia%20t%C3%A9cnica%2C%20cient%C3%ADfica%20e%20funcional%2C%20exigido%20concurso%20p%C3%BAblico%2C",
      "keywords": [],
